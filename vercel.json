{
  "version": 2,
  "installCommand": "npm ci && cd app && npm ci",
  "buildCommand": "cd app && npm run build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
