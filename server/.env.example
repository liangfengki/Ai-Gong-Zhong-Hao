# AI公众号写作助手 - 服务端配置
# ==========================================

# 服务器端口
PORT=6356

# DailyHotApi 地址（热点聚合服务，本地运行在 6688 端口）
DAILYHOT_API=http://localhost:6688

# ============ AI API 配置 ============
# 优先级：前端设置页 > 此文件配置

# DeepSeek API（默认）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
DEFAULT_API_KEY=
DEFAULT_MODEL=deepseek-chat

# ============ 图片 API 配置 ============
# 留空则使用免费的 Lorem Picsum 替代
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ============ 安全配置 ============

# JWT 密钥（生产环境请使用强随机字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT 令牌过期时间（默认 24 小时）
JWT_EXPIRES_IN=24h

# CORS 允许的源（生产环境使用逗号分隔的域名列表）
# 示例：CORS_ORIGIN=https://example.com,https://www.example.com
CORS_ORIGIN=

# 环境（development/production）
NODE_ENV=development
