# AI公众号写作助手 - 服务端配置
# ==========================================

# 服务器端口
PORT=6356

# DailyHotApi 地址（热点聚合服务，本地运行在 6688 端口）
DAILYHOT_API=http://localhost:6688

# ============ AI API 配置 ============
# 优先级：前端设置页 > 此文件配置

# DeepSeek API（默认）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
DEFAULT_API_KEY=
DEFAULT_MODEL=deepseek-chat

# ============ 图片 API 配置 ============
# 留空则使用免费的 Lorem Picsum 替代
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
